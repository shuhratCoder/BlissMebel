# Template for local environment. Copy to .env.local and fill in.
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# Mebel backend (proxied via /mebel/* rewrite in next.config.js).
# Must be reachable from the host running `next dev` / `next start`.
BACKEND_API_URL=http://192.168.8.222:3008

# Mokky.dev test backend — temporary, used for clients/orders/payment history.
# Remove once the real backend (/mebel) covers these resources.
NEXT_PUBLIC_MOKKY_BASE=https://8f894bfeecc56ce9.mokky.dev

# Eskiz SMS sender configuration. Must match the values approved in the
# notify.eskiz.uz cabinet. Wrong values cause SMS to be rejected.
NEXT_PUBLIC_ESKIZ_FROM=4546
NEXT_PUBLIC_ESKIZ_DISPATCH_ID=75424
